{
  "name": "reveal.js",
  "version": "5.0.2",
  "description": "The HTML Presentation Framework",
  "homepage": "https://revealjs.com",
  "subdomain": "revealjs",
  "main": "dist/reveal.js",
  "module": "dist/reveal.esm.js",
  "license": "MIT",
  "scripts": {
    "test": "npm run lint && npm run qunit",
    "start": "webpack serve --config webpack.dev.js",
    "build": "node webpack.config.js",
    "build:js": "node webpack.config.js --config-name=reveal-js",
    "build:css": "node webpack.config.js --config-name=reveal-css",
    "build:plugin": "node webpack.config.js --config-name=plugin-highlight",
    "lint": "eslint ./js/**",
    "qunit": "node test/runner.js"
  },
  "author": {
    "name": "Hakim El Hattab",
    "email": "hakim.elhattab@gmail.com",
    "web": "https://hakim.se"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/hakimel/reveal.js.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "reveal",
    "slides",
    "presentation"
  ],
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/eslint-parser": "^7.22.15",
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-react": "^7.28.5",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-loader": "^10.1.0",
    "babel-plugin-transform-html-import-to-string": "2.0.0",
    "colors": "^1.4.0",
    "copy-webpack-plugin": "^14.0.0",
    "core-js": "^3.33.1",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^7.0.4",
    "fitty": "^2.3.7",
    "glob": "^10.3.10",
    "gulp-connect": "^5.7.0",
    "highlight.js": "^11.9.0",
    "marked": "^4.3.0",
    "mini-css-extract-plugin": "^2.10.0",
    "node-qunit-puppeteer": "^2.1.2",
    "qunit": "^2.20.0",
    "resolve-url-loader": "^5.0.0",
    "rollup": "^4.1.5",
    "sass": "^1.69.5",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.17",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "yargs": "^17.7.2"
  },
  "overrides": {
    "chokidar": "3.5.3",
    "glob-parent": "6.0.2"
  },
  "browserslist": "> 2%, not dead",
  "eslintConfig": {
    "env": {
      "browser": true,
      "es6": true
    },
    "parser": "@babel/eslint-parser",
    "parserOptions": {
      "sourceType": "module",
      "allowImportExportEverywhere": true,
      "requireConfigFile": false
    },
    "globals": {
      "module": false,
      "console": false,
      "unescape": false,
      "define": false,
      "exports": false
    },
    "rules": {
      "curly": 0,
      "eqeqeq": 2,
      "wrap-iife": [
        2,
        "any"
      ],
      "no-use-before-define": [
        2,
        {
          "functions": false
        }
      ],
      "new-cap": 2,
      "no-caller": 2,
      "dot-notation": 0,
      "no-eq-null": 2,
      "no-unused-expressions": 0
    }
  },
  "dependencies": {
    "reveal.js-mermaid-plugin": "^2.0.0"
  }
}
